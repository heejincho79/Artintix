{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "A business inquiry or energy audit request from a potential client.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the inquirer."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Contact email address."
        },
        "company": {
          "type": "string",
          "description": "Company name."
        },
        "interest": {
          "type": "string",
          "description": "Selected area of interest."
        },
        "wantsAudit": {
          "type": "boolean",
          "description": "Whether the user requested a free energy audit."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the inquiry."
        },
        "status": {
          "type": "string",
          "enum": ["new", "contacted", "closed"],
          "description": "Processing status of the lead."
        }
      },
      "required": ["name", "email", "company", "interest", "createdAt"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of business leads and audit requests."
    }
  }
}
